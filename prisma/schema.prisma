generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String     @id @default(cuid())
  name              String
  phone             String     @unique
  password          String
  isPasswordChanged Boolean    @default(false)
  role              Role       @default(USER)
  status            UserStatus @default(ACTIVE)

  captainProfile   Captain?
  secretaryProfile Secretary?

  academies        Academy[]            @relation("AcademyOwners")
  receivedPayments PaymentTransaction[] @relation("PaymentReceiver")

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  logoutAt      DateTime?
  subscriptions Subscription[]

  @@index([role])
}

model BlacklistedToken {
  id        String   @id @default(cuid())
  jti       String   @unique
  expiresAt DateTime

  @@index([expiresAt])
}

model Academy {
  id       String  @id @default(cuid())
  name     String  @unique
  phone    String  @unique
  address  String
  instaPay String?

  socialMediaPlatforms SocialMedia[]
  owners               User[]               @relation("AcademyOwners")
  courses              Course[]
  subscriptions        Subscription[]
  expenses             Expense[]
  clients              Client[]
  Lessons              Lesson[]
  payments             PaymentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialMedia {
  id        String   @id @default(cuid())
  platform  Platform
  url       String
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id], onDelete: Restrict)

  @@unique([platform, academyId])
}

model Secretary {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  baseSalary  Float
  targetCount Int
  bonusAmount Float
  createdAt   DateTime @default(now())
}

model Captain {
  id                 String          @id @default(cuid())
  userId             String          @unique
  user               User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  isActive           Boolean         @default(true)
  captainLessonPrice Float
  trainingType       TrainingSupport @default(BOTH)
  createdAt          DateTime        @default(now())

  lessons Lesson[] @relation("CaptainLessons")

  @@index([isActive, trainingType])
}

model Car {
  id              String       @id @default(cuid())
  modelName       String
  plateNumber     String       @unique
  gearType        Transmission
  carSessionPrice Float        @default(0)
  isActive        Boolean      @default(true)
  lessons         Lesson[]
  createdAt       DateTime     @default(now())

  @@index([isActive, gearType])
}

model Area {
  id          String          @id @default(cuid())
  name        String          @unique
  supportType TrainingSupport
  isActive    Boolean         @default(true)
  lessons     Lesson[]
  createdAt   DateTime        @default(now())

  @@index([isActive])
  @@index([supportType])
}

model Client {
  id           String       @id @default(cuid())
  name         String
  phone        String
  clientSource ClientSource

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  subscriptions Subscription[]
  lessons       Lesson[]
  payments      PaymentTransaction[]

  createdAt DateTime @default(now())

  @@unique([academyId, phone])
  @@unique([academyId, id])
  @@index([academyId])
  @@index([name])
  @@index([phone])
}

model Subscription {
  id                         String             @id @default(cuid())
  status                     SubscriptionStatus @default(PENDING_PAYMENT)
  priceAtBooking             Float
  totalSessions              Int
  sessionDurationMinutes     Int
  trainingTypeAtRegistration Transmission       @default(AUTOMATIC)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  lessons      Lesson[]
  payments     PaymentTransaction[]
  cancellation SubscriptionCancellation?

  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([academyId])
}

model PaymentTransaction {
  id            String          @id @default(cuid())
  amount        Float
  paymentMethod PaymentMethod
  type          TransactionType @default(PAYMENT)
  status        Status          @default(PENDING)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  lessonId String? @unique
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: Restrict)

  receiverId String
  receiver   User   @relation("PaymentReceiver", fields: [receiverId], references: [id], onDelete: Restrict)

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptionCancellations SubscriptionCancellation[]

  @@index([receiverId])
  @@index([subscriptionId])
  @@index([createdAt])
  @@index([status])
}

model Lesson {
  id                 String       @id @default(cuid())
  startTime          DateTime
  endTime            DateTime
  status             LessonStatus @default(SCHEDULED)
  transmission       Transmission
  expectedAmount     Float?
  carSessionPrice    Float
  captainLessonPrice Float

  captainId String
  captain   Captain @relation("CaptainLessons", fields: [captainId], references: [id], onDelete: Restrict)

  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Restrict)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  areaId String
  area   Area   @relation(fields: [areaId], references: [id], onDelete: Restrict)

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  paymentTransaction PaymentTransaction?

  @@index([captainId, startTime, endTime])
  @@index([carId, startTime, endTime])
  @@index([clientId, startTime, endTime])
  @@index([status])
}

model SubscriptionCancellation {
  id String @id @default(cuid())

  subscriptionId String       @unique
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  reason CancelReason

  refundTransactionId String?
  refundTransaction   PaymentTransaction? @relation(fields: [refundTransactionId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
}

model Course {
  id                     String   @id @default(cuid())
  name                   String
  description            String
  isActive               Boolean  @default(true)
  priceOriginal          Float
  priceDiscounted        Float
  totalSessions          Int
  practicalSessions      Int
  sessionDurationMinutes Int
  trainingDetails        String[]
  featuredReason         String?

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academyId, name])
  @@unique([academyId, id])
  @@index([name])
}

model Expense {
  id     String      @id @default(cuid())
  amount Float
  type   ExpenseType

  academyId String
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([academyId, createdAt])
}

enum Role {
  OWNER
  SECRETARY
  CAPTAIN
  USER
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum TrainingSupport {
  MANUAL
  AUTOMATIC
  BOTH
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  CANCELED_CHARGED
}

enum ExpenseType {
  MARKETING
  MAINTENANCE
  UTILITIES
  RENT
  GENERAL
}

enum CancelReason {
  CHANGE_PROGRAM
  DOES_NOT_WANT_COURSE
  CAPTAIN_ISSUE
  MANAGEMENT_ISSUE
  ABSENCE_EXCEEDED
  OTHER
}

enum PaymentMethod {
  CASH
  ELECTRONIC_WALLET
}

enum TransactionType {
  PAYMENT
  REFUND
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  YOUTUBE
  WHATSAPP
  WEBSITE
  GMAIL
}

enum Status {
  PENDING
  COMPLETED
  REJECTED
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  PAID_WAITING_BOOKING
  BOOKED_NOT_STARTED // حجز لكن أول حصة لم تتم
  ACTIVE // شغال
  PAUSED // متوقف مؤقت
  POSTPONED // مؤجل
  COMPLETED // خلص
  CANCELED // اتلغى
}

enum ClientSource {
  PLATFORM
  OFFICE
}
